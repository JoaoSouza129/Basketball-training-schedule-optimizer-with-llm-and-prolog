{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Input Profile - Basketball Training Optimizer",
  "type": "object",
  "required": [
    "profile",
    "primary_goal",
    "availability",
    "physical_restrictions"
  ],
  "properties": {
    "profile": {
      "type": "object",
      "required": ["level", "experience_years"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"]
        },
        "experience_years": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50
        }
      }
    },
    "primary_goal": {
      "type": "string",
      "enum": ["shooting", "dribbling", "defense", "conditioning", "strength", "mixed", "plyometrics"]
    },
    "availability": {
      "type": "object",
      "required": ["days_per_week", "minutes_per_day", "available_days"],
      "properties": {
        "days_per_week": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "minutes_per_day": {
          "type": "integer",
          "minimum": 20,
          "maximum": 180
        },
        "available_days": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
          }
        }
      }
    },
    "physical_restrictions": {
      "type": "object",
      "required": ["has_injury"],
      "properties": {
        "has_injury": {
          "type": "boolean"
        },
        "injury_region": {
          "type": ["string", "null"],
          "enum": [null, "knee", "ankle", "shoulder", "back", "hip"]
        }
      }
    },
    "position": {
      "type": ["string", "null"],
      "enum": [null, "PG", "SG", "SF", "PF", "C"]
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["basketball", "cones", "resistance_bands", "weights", "heavy_ball", "court", "basket", "box_or_step", "foam_roller"]
      },
      "default": ["basketball", "court", "basket"],
      "uniqueItems": true
    },
    "preferences": {
      "type": "object",
      "properties": {
        "liked_blocks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disliked_blocks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "secondary_goal": {
      "type": ["string", "null"],
      "enum": [null, "strength", "flexibility", "finishing", "vertical_jump"]
    },
    "competition_day": {
      "type": ["string", "null"],
      "enum": [null, "monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
    },
    "initial_metrics": {
      "type": ["object", "null"],
      "properties": {
        "shooting_percentage": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "sprint_20m_seconds": {
          "type": ["number", "null"],
          "minimum": 2.0,
          "maximum": 10.0
        },
        "vertical_jump_cm": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 150
        }
      }
    }
  }
}
