{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weekly Plan Output - LLM Generated",
  "type": "object",
  "required": ["weekly_plan", "rationale", "assumptions"],
  "properties": {
    "weekly_plan": {
      "type": "object",
      "required": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
      "properties": {
        "monday": { "$ref": "#/definitions/training_day" },
        "tuesday": { "$ref": "#/definitions/training_day" },
        "wednesday": { "$ref": "#/definitions/training_day" },
        "thursday": { "$ref": "#/definitions/training_day" },
        "friday": { "$ref": "#/definitions/training_day" },
        "saturday": { "$ref": "#/definitions/training_day" },
        "sunday": { "$ref": "#/definitions/training_day" }
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "training_day": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["total_minutes", "sessions"],
          "properties": {
            "total_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "sessions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/session_block" }
            }
          }
        }
      ]
    },
    "session_block": {
      "type": "object",
      "required": ["block_id", "name", "duration_minutes", "intensity", "focus", "tags"],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "intensity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "focus": {
          "type": "string",
          "enum": ["physical", "technical", "recovery"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
